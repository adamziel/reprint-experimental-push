{
  "name": "reprint-experimental-push",
  "version": "0.0.0",
  "description": "Experimental push-back planner and research harness for Reprint.",
  "type": "module",
  "private": false,
  "bin": {
    "reprint-push-lab": "./bin/reprint-push-lab.js"
  },
  "scripts": {
    "test": "node --test",
    "test:playground": "npm run test:playground:plan && npm run test:playground:apply && npm run test:playground:push-protocol",
    "test:playground:plan": "node ./scripts/playground/plan-from-blueprints.mjs",
    "test:playground:apply": "node ./scripts/playground/apply-ready-plan.mjs",
    "test:playground:push-protocol": "node ./scripts/playground/push-protocol-smoke.mjs",
    "test:playground:forms-lab-table": "node ./scripts/playground/forms-lab-table-driver-smoke.mjs",
    "test:playground:http-push": "node ./scripts/playground/http-push-smoke.mjs",
    "test:playground:authenticated-http-push": "node ./scripts/playground/authenticated-http-push-smoke.mjs",
    "test:playground:authenticated-cli-push": "node ./scripts/playground/authenticated-cli-push-smoke.mjs",
    "test:playground:production-shaped-push": "node ./scripts/playground/production-shaped-route-smoke.mjs",
    "test:playground:production-shaped-topology-proof": "node ./scripts/playground/production-shaped-topology-proof.mjs",
    "test:playground:production-shaped-live-topology-proof": "node ./scripts/playground/production-shaped-live-topology-proof.mjs",
    "test:playground:production-shaped-live-protocol-proof": "node ./scripts/playground/production-shaped-live-protocol-proof.mjs",
    "test:playground:production-shaped-release-proof": "node ./scripts/playground/production-shaped-release-proof.mjs",
    "test:playground:production-shaped-live-source-gate": "node ./scripts/playground/production-shaped-live-source-gate-smoke.mjs",
    "test:playground:production-shaped-apply-revalidation": "node ./scripts/playground/production-shaped-apply-revalidation-smoke.mjs",
    "test:playground:production-shaped-missing-secret": "node ./scripts/playground/production-shaped-missing-secret-smoke.mjs",
    "test:playground:production-shaped-missing-live-source": "node ./scripts/playground/production-shaped-live-source-gate-smoke.mjs",
    "test:playground:production-shaped-live-preflight": "node ./scripts/playground/production-shaped-live-preflight-smoke.mjs",
    "test:playground:production-shaped-release-verify": "node ./scripts/playground/production-shaped-release-verify.mjs",
    "test:playground:production-shaped-live-release-verify": "node ./scripts/playground/production-shaped-live-release-verify.mjs",
    "test:playground:production-plugin-driver-verifier-guards": "REPRINT_PUSH_PACKAGE_SMOKE_MODE=driver-guard-only REPRINT_PUSH_PACKAGE_SMOKE_SCENARIO=driver-verifier-guards node ./scripts/playground/production-plugin-package-smoke.mjs",
    "verify:release": "npm run test:playground:production-shaped-topology-proof && REPRINT_PUSH_REQUIRE_PRODUCTION_AUTH_SESSION=1 REPRINT_PUSH_REQUIRE_PRODUCTION_DURABLE_JOURNAL=1 REPRINT_PUSH_SIMULATE_PRESERVED_REMOTE_RETRY_PATH=/snapshot npm run test:playground:production-shaped-live-release-verify && npm run test:playground:production-plugin-driver-verifier-guards && npm run test:recovery:file-journal",
    "verify:release:local-production": "node ./scripts/playground/local-production-release-verify.mjs",
    "verify:release:local-production:complex-site": "REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_SITE_PROOF=1 node ./scripts/playground/local-production-release-verify.mjs",
    "verify:release:local-production:complex-site:plugin-driver": "REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_SITE_PROOF=1 node ./scripts/playground/local-production-release-verify.mjs",
    "verify:release:local-production:complex-site:graph": "REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_SITE_PROOF=1 REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_GRAPH_PROOF=1 node ./scripts/playground/local-production-release-verify.mjs",
    "verify:release:local-production:complex-site:taxonomy-graph": "REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_SITE_PROOF=1 REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_TAXONOMY_GRAPH_PROOF=1 node ./scripts/playground/local-production-release-verify.mjs",
    "verify:release:local-production:complex-site:post-parent-graph": "REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_SITE_PROOF=1 REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_POST_PARENT_GRAPH_PROOF=1 node ./scripts/playground/local-production-release-verify.mjs",
    "verify:release:local-production:complex-site:comment-graph": "REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_SITE_PROOF=1 REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_COMMENT_GRAPH_PROOF=1 node ./scripts/playground/local-production-release-verify.mjs",
    "verify:release:local-production:complex-site:journal-window": "REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_SITE_PROOF=1 REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_POST_COUNT=25 node ./scripts/playground/local-production-release-verify.mjs",
    "verify:release:local-production:complex-site:journal-pages": "REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_SITE_PROOF=1 REPRINT_PUSH_LOCAL_PRODUCTION_COMPLEX_POST_COUNT=180 REPRINT_PUSH_AUTHENTICATED_REQUEST_TIMEOUT_MS=180000 REPRINT_PUSH_LIVE_RELEASE_VERIFY_TIMEOUT_MS=600000 node ./scripts/playground/local-production-release-verify.mjs",
    "test:playground:local-production-complex-site-proof": "node --test test/local-production-complex-site-proof.test.js",
    "test:generated-push-harness": "node --test test/generated-push-harness.test.js",
    "test:playground:production-shaped-proof": "node ./scripts/playground/production-shaped-proof.mjs",
    "test:playground:production-plugin-package": "node ./scripts/playground/production-plugin-package-smoke.mjs",
    "test:playground:plugin-atomic-install": "node ./scripts/playground/plugin-atomic-install-smoke.mjs",
    "test:playground:db-journal-idempotency": "node ./scripts/playground/db-journal-idempotency-smoke.mjs",
    "test:playground:storage-guarded-db-write": "node ./scripts/playground/storage-guarded-db-write-smoke.mjs",
    "test:playground:storage-guarded-file-write": "node ./scripts/playground/storage-guarded-file-write-smoke.mjs",
    "test:playground:mid-apply-drift": "node ./scripts/playground/mid-apply-drift-smoke.mjs",
    "test:playground:db-journal-process-kill": "node ./scripts/playground/db-journal-process-kill-smoke.mjs",
    "test:playground:db-journal-missing-commit-finalization": "node ./scripts/playground/db-journal-missing-commit-finalization-smoke.mjs",
    "test:playground:db-journal-stale-claim-all-old": "node ./scripts/playground/db-journal-stale-claim-all-old-smoke.mjs",
    "test:playground:recovery": "node ./scripts/playground/recovery-smoke.mjs",
    "test:recovery:file-journal": "node ./scripts/recovery/file-journal-restart-smoke.mjs",
    "bench:graph-mapping-inventory": "node ./scripts/bench/graph-mapping-inventory.js",
    "plan": "node ./bin/reprint-push-lab.js plan",
    "apply": "node ./bin/reprint-push-lab.js apply",
    "verify:release:docker-local-production": "node ./scripts/docker/production-complex-site-harness.mjs",
    "test:docker:production-complex-site-harness": "node --test test/production-complex-site-harness.test.js",
    "check:release-gates": "node ./scripts/release/check-release-gates.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "GPL-2.0-or-later"
}
