{
  "name": "reprint-experimental-push",
  "version": "0.0.0",
  "description": "Experimental push-back planner and research harness for Reprint.",
  "type": "module",
  "private": false,
  "bin": {
    "reprint-push-lab": "./bin/reprint-push-lab.js"
  },
  "scripts": {
    "test": "node --test",
    "test:playground": "npm run test:playground:plan && npm run test:playground:apply && npm run test:playground:push-protocol",
    "test:playground:plan": "node ./scripts/playground/plan-from-blueprints.mjs",
    "test:playground:apply": "node ./scripts/playground/apply-ready-plan.mjs",
    "test:playground:push-protocol": "node ./scripts/playground/push-protocol-smoke.mjs",
    "test:playground:http-push": "node ./scripts/playground/http-push-smoke.mjs",
    "plan": "node ./bin/reprint-push-lab.js plan",
    "apply": "node ./bin/reprint-push-lab.js apply"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "GPL-2.0-or-later"
}
