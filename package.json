{
  "name": "reprint-experimental-push",
  "version": "0.0.0",
  "description": "Experimental push-back planner and research harness for Reprint.",
  "type": "module",
  "private": false,
  "bin": {
    "reprint-push-lab": "./bin/reprint-push-lab.js"
  },
  "scripts": {
    "test": "node --test",
    "test:playground": "npm run test:playground:plan && npm run test:playground:apply && npm run test:playground:push-protocol",
    "test:playground:plan": "node ./scripts/playground/plan-from-blueprints.mjs",
    "test:playground:apply": "node ./scripts/playground/apply-ready-plan.mjs",
    "test:playground:push-protocol": "node ./scripts/playground/push-protocol-smoke.mjs",
    "test:playground:forms-lab-table": "node ./scripts/playground/forms-lab-table-driver-smoke.mjs",
    "test:playground:http-push": "node ./scripts/playground/http-push-smoke.mjs",
    "test:playground:authenticated-http-push": "node ./scripts/playground/authenticated-http-push-smoke.mjs",
    "test:playground:authenticated-cli-push": "node ./scripts/playground/authenticated-cli-push-smoke.mjs",
    "test:playground:production-shaped-push": "node ./scripts/playground/production-shaped-route-smoke.mjs",
    "test:playground:production-shaped-missing-secret": "node ./scripts/playground/production-shaped-missing-secret-smoke.mjs",
    "test:playground:production-shaped-proof": "node ./scripts/playground/production-shaped-proof.mjs",
    "test:playground:production-plugin-package": "node ./scripts/playground/production-plugin-package-smoke.mjs",
    "test:playground:plugin-atomic-install": "node ./scripts/playground/plugin-atomic-install-smoke.mjs",
    "test:playground:db-journal-idempotency": "node ./scripts/playground/db-journal-idempotency-smoke.mjs",
    "test:playground:storage-guarded-db-write": "node ./scripts/playground/storage-guarded-db-write-smoke.mjs",
    "test:playground:storage-guarded-file-write": "node ./scripts/playground/storage-guarded-file-write-smoke.mjs",
    "test:playground:mid-apply-drift": "node ./scripts/playground/mid-apply-drift-smoke.mjs",
    "test:playground:db-journal-process-kill": "node ./scripts/playground/db-journal-process-kill-smoke.mjs",
    "test:playground:db-journal-missing-commit-finalization": "node ./scripts/playground/db-journal-missing-commit-finalization-smoke.mjs",
    "test:playground:db-journal-stale-claim-all-old": "node ./scripts/playground/db-journal-stale-claim-all-old-smoke.mjs",
    "test:playground:recovery": "node ./scripts/playground/recovery-smoke.mjs",
    "test:recovery:file-journal": "node ./scripts/recovery/file-journal-restart-smoke.mjs",
    "plan": "node ./bin/reprint-push-lab.js plan",
    "apply": "node ./bin/reprint-push-lab.js apply"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "GPL-2.0-or-later"
}
